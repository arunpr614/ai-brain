{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brain.arunp.in/schemas/normalized-transcript-v1.json",
  "title": "Normalized timestamped transcript",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "item_id",
    "youtube_video_id",
    "source_method",
    "language",
    "caption_type",
    "timestamp_mode",
    "completeness",
    "provenance",
    "processing_version",
    "segments",
    "errors"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "item_id": { "type": "string", "pattern": "^YT-[0-9]{2}$" },
    "youtube_video_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{11}$" },
    "source_method": { "enum": ["A1", "A2", "A3"] },
    "language": { "type": "string", "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$" },
    "caption_type": { "enum": ["source_provided_unknown_authorship", "human", "automatic", "translated", "unknown"] },
    "timestamp_mode": { "const": "timestamped" },
    "completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "basis", "source_duration_ms", "last_cue_end_ms", "trailing_gap_ms"],
      "properties": {
        "state": { "enum": ["complete", "partial", "unknown"] },
        "basis": { "enum": ["explicit_source_assertion", "source_coverage_record", "user_attestation", "unknown"] },
        "source_duration_ms": { "type": "integer", "minimum": 1 },
        "last_cue_end_ms": { "type": "integer", "minimum": 0 },
        "trailing_gap_ms": { "type": "integer", "minimum": 0 },
        "missing_intervals": {
          "type": "array",
          "items": { "$ref": "#/$defs/interval" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_page_url", "source_asset_url", "input_sha256", "reference_role", "version_equivalence", "acquired_at"],
      "properties": {
        "source_page_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "source_asset_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "reference_role": { "enum": ["input_preservation", "independent_speech"] },
        "version_equivalence": { "enum": ["official_row_level_publication_association", "owner_verified_exact"] },
        "acquired_at": { "type": "string", "format": "date-time" }
      }
    },
    "processing_version": { "type": "string", "minLength": 1 },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "start_ms",
          "end_ms",
          "source_start_ms",
          "source_end_ms",
          "text",
          "source_cue_ids"
        ],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "start_ms": { "type": "integer", "minimum": 0 },
          "end_ms": { "type": "integer", "minimum": 0 },
          "source_start_ms": { "type": "integer", "minimum": 0 },
          "source_end_ms": { "type": "integer", "minimum": 0 },
          "text": { "type": "string", "minLength": 1 },
          "speaker": { "type": ["string", "null"] },
          "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "source_cue_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "recoverable"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "recoverable": { "type": "boolean" }
        }
      }
    }
  },
  "$defs": {
    "interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_ms", "end_ms", "reason"],
      "properties": {
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
