{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brain.arunp.in/schemas/youtube-local-evaluator-run-report-v1.json",
  "title": "Publication-safe write-once local blinded evaluator process report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "runner_version", "execution_class", "publication_eligible", "role", "state", "packet_id", "packet_sha256", "result_sha256", "started_at", "completed_at", "duration_ms", "process", "bindings", "boundary", "failure_code", "claims_boundary"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "runner_version": { "const": "1.0.0" },
    "execution_class": { "enum": ["SEALED", "DEV_TEST"] },
    "publication_eligible": { "type": "boolean" },
    "role": { "enum": ["evaluator_a", "evaluator_b", "adjudicator"] },
    "state": { "enum": ["succeeded", "failed"] },
    "packet_id": { "type": "string", "pattern": "^G4-EVAL-(?:[AB]|J)-[0-9a-f]{12}$" },
    "packet_sha256": { "$ref": "#/$defs/sha256" },
    "result_sha256": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "started_at": { "$ref": "#/$defs/dateTime" },
    "completed_at": { "$ref": "#/$defs/dateTime" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "process": {
      "type": "object", "additionalProperties": false,
      "required": ["invocation_count", "timeout_ms", "exit_code", "signal", "timed_out", "output_overflow", "stdout_bytes", "stdout_retained_bytes", "stdout_sha256", "stderr_bytes", "stderr_retained_bytes", "stderr_sha256", "maximum_resident_set_size_bytes", "peak_memory_footprint_bytes"],
      "properties": {
        "invocation_count": { "const": 1 },
        "timeout_ms": { "const": 1800000 },
        "exit_code": { "anyOf": [{ "type": "integer" }, { "type": "null" }] },
        "signal": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
        "timed_out": { "type": "boolean" },
        "output_overflow": { "type": "boolean" },
        "stdout_bytes": { "type": "integer", "minimum": 0 },
        "stdout_retained_bytes": { "type": "integer", "minimum": 0, "maximum": 4194304 },
        "stdout_sha256": { "$ref": "#/$defs/sha256" },
        "stderr_bytes": { "type": "integer", "minimum": 0 },
        "stderr_retained_bytes": { "type": "integer", "minimum": 0, "maximum": 4194304 },
        "stderr_sha256": { "$ref": "#/$defs/sha256" },
        "maximum_resident_set_size_bytes": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "peak_memory_footprint_bytes": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }
      }
    },
    "bindings": {
      "type": "object", "additionalProperties": false,
      "required": ["content_commit", "seal_commit", "benchmark_lock_sha256", "public_package_attempt_claim_sha256", "public_role_attempt_claim_sha256", "execution_contract_sha256", "runtime_ledger_sha256", "llama_cli_sha256", "model_sha256", "role_system_prompt_sha256", "role_generation_schema_sha256", "strict_postparse_schema_sha256", "sandbox_profile_sha256", "post_execution_reverified"],
      "properties": {
        "content_commit": { "$ref": "#/$defs/gitSha" }, "seal_commit": { "$ref": "#/$defs/gitSha" },
        "benchmark_lock_sha256": { "$ref": "#/$defs/sha256" },
        "public_package_attempt_claim_sha256": { "$ref": "#/$defs/sha256" }, "public_role_attempt_claim_sha256": { "$ref": "#/$defs/sha256" },
        "execution_contract_sha256": { "$ref": "#/$defs/sha256" },
        "runtime_ledger_sha256": { "$ref": "#/$defs/sha256" }, "llama_cli_sha256": { "$ref": "#/$defs/sha256" },
        "model_sha256": { "$ref": "#/$defs/sha256" }, "role_system_prompt_sha256": { "$ref": "#/$defs/sha256" },
        "role_generation_schema_sha256": { "$ref": "#/$defs/sha256" }, "strict_postparse_schema_sha256": { "$ref": "#/$defs/sha256" }, "sandbox_profile_sha256": { "$ref": "#/$defs/sha256" },
        "post_execution_reverified": { "type": "boolean" }
      }
    },
    "boundary": {
      "type": "object", "additionalProperties": false,
      "required": ["local_private_process", "fresh_process", "packet_only_file_context", "network_denied", "tools_available", "external_provider_calls", "external_content_transfer", "incremental_spend_usd", "training_performed", "same_model_evaluator_bias"],
      "properties": {
        "local_private_process": { "const": true }, "fresh_process": { "const": true }, "packet_only_file_context": { "const": true },
        "network_denied": { "const": true }, "tools_available": { "const": false }, "external_provider_calls": { "const": 0 },
        "external_content_transfer": { "const": false }, "incremental_spend_usd": { "const": 0 }, "training_performed": { "const": false },
        "same_model_evaluator_bias": { "const": "disclosed_material_reproducibility_limitation" }
      }
    },
    "failure_code": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
    "claims_boundary": { "const": "ai_evaluated_provisional_pending_human_stakeholder_review" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "dateTime": { "type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$" }
  },
  "allOf": [
    { "if": { "properties": { "execution_class": { "const": "SEALED" } } }, "then": { "properties": { "publication_eligible": { "const": true } } } },
    { "if": { "properties": { "execution_class": { "const": "DEV_TEST" } } }, "then": { "properties": { "publication_eligible": { "const": false } } } },
    { "if": { "properties": { "state": { "const": "succeeded" } } }, "then": { "properties": { "result_sha256": { "$ref": "#/$defs/sha256" }, "failure_code": { "type": "null" } } } },
    { "if": { "properties": { "state": { "const": "failed" } } }, "then": { "properties": { "result_sha256": { "type": "null" }, "failure_code": { "type": "string", "minLength": 1 } } } }
  ]
}
