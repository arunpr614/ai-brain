{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brain.arunp.in/schemas/youtube-blinded-adjudication-packet-v1.json",
  "title": "Exact-five blinded Gate 4 adjudication packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "packet_id", "role", "content_commit", "seal_commit", "benchmark_lock_sha256", "execution_contract_sha256", "execution_readiness_sha256", "consent_attestation_sha256", "runtime_ledger_sha256", "role_system_prompt_sha256", "role_generation_schema_sha256", "sandbox_profile_sha256", "source_evaluator_result_sha256", "items", "instructions", "claims_boundary"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "packet_id": { "type": "string", "pattern": "^G4-EVAL-J-[0-9a-f]{12}$" },
    "role": { "const": "adjudicator" },
    "content_commit": { "$ref": "#/$defs/gitSha" },
    "seal_commit": { "$ref": "#/$defs/gitSha" },
    "benchmark_lock_sha256": { "$ref": "#/$defs/sha256" },
    "execution_contract_sha256": { "$ref": "#/$defs/sha256" },
    "execution_readiness_sha256": { "$ref": "#/$defs/sha256" },
    "consent_attestation_sha256": { "$ref": "#/$defs/sha256" },
    "runtime_ledger_sha256": { "$ref": "#/$defs/sha256" },
    "role_system_prompt_sha256": { "const": "1118a1683b3f8b2c5d253f2aa0b8e0db02df6601136f2fbbf106fea8998a5ad9" },
    "role_generation_schema_sha256": { "const": "f0eaa99b6f689a48242b52465334a87f17a7f582d12cabbc7fcfb77ccc800396" },
    "sandbox_profile_sha256": { "$ref": "#/$defs/sha256" },
    "source_evaluator_result_sha256": {
      "type": "object", "additionalProperties": false,
      "required": ["evaluator_a", "evaluator_b"],
      "properties": { "evaluator_a": { "$ref": "#/$defs/sha256" }, "evaluator_b": { "$ref": "#/$defs/sha256" } }
    },
    "items": {
      "type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["blinded_item_id", "disputes"],
        "properties": {
          "blinded_item_id": { "type": "string", "pattern": "^J00[1-5]$" },
          "disputes": {
            "type": "array", "maxItems": 100, "uniqueItems": true,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["dispute_id", "kind", "subject_id", "evaluator_a", "evaluator_b", "approved_excerpts"],
              "properties": {
                "dispute_id": { "type": "string", "pattern": "^D[0-9a-f]{12}$" },
                "kind": { "enum": ["claim_support", "citation_accuracy", "text_key_point", "visual_key_point", "critical_hallucinations", "schema_reference_issues"] },
                "subject_id": { "type": "string", "pattern": "^(ITEM|C[0-9]{3}|Q[0-9]{3}|[TV][0-9]{3})$" },
                "evaluator_a": { "$ref": "#/$defs/option" },
                "evaluator_b": { "$ref": "#/$defs/option" },
                "approved_excerpts": {
                  "type": "array", "maxItems": 12, "uniqueItems": true,
                  "items": {
                    "type": "object", "additionalProperties": false,
                    "required": ["excerpt_id", "text"],
                    "properties": {
                      "excerpt_id": { "type": "string", "pattern": "^E[0-9]{3}$" },
                      "text": { "type": "string", "minLength": 1, "maxLength": 1000 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "instructions": {
      "type": "object", "additionalProperties": false,
      "required": ["select_exactly_one_original_option_per_dispute", "no_new_score_or_additional_evidence", "no_tools_network_or_external_calls"],
      "properties": {
        "select_exactly_one_original_option_per_dispute": { "const": true },
        "no_new_score_or_additional_evidence": { "const": true },
        "no_tools_network_or_external_calls": { "const": true }
      }
    },
    "claims_boundary": { "const": "ai_evaluated_provisional_pending_human_stakeholder_review" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "option": {
      "type": "object", "additionalProperties": false,
      "required": ["value", "rationale"],
      "properties": {
        "value": {},
        "rationale": { "type": "string", "minLength": 1, "maxLength": 1200 }
      }
    }
  }
}
