{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brain.arunp.in/schemas/youtube-a1-execution-contract-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "contract_id", "operator_version", "receipt_schema_version", "attempt_claim_schema_version", "attempt_terminal_schema_version", "child_timeout_ms", "execution_boundary", "runtime", "attempt", "oracle", "publication"],
  "properties": {
    "$schema": { "const": "https://brain.arunp.in/schemas/youtube-a1-execution-contract-v1.json" },
    "schema_version": { "const": "1.0" },
    "contract_id": { "const": "sealed-a1-write-once-attempt-v1" },
    "operator_version": { "const": "1.1.0" },
    "receipt_schema_version": { "const": "1.1" },
    "attempt_claim_schema_version": { "const": "1.0" },
    "attempt_terminal_schema_version": { "const": "1.0" },
    "child_timeout_ms": { "const": 120000 },
    "execution_boundary": { "const": "sealed_default_dependencies" },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_executable", "path", "git_executable_precedence", "tsx_cache_disabled", "transcript_policy_environment", "network", "filesystem_default", "repository_data_reads", "repository_directory_reads", "unfrozen_repository_file_data", "private_writes", "node_modules"],
      "properties": {
        "node_executable": { "const": "/opt/homebrew/opt/node@22/bin/node" },
        "path": { "const": "/Library/Developer/CommandLineTools/usr/bin:/usr/bin:/bin" },
        "git_executable_precedence": { "const": "/Library/Developer/CommandLineTools/usr/bin/git" },
        "tsx_cache_disabled": { "const": true },
        "transcript_policy_environment": { "const": "lab" },
        "network": { "const": "deny_all" },
        "filesystem_default": { "const": "deny_read_and_write" },
        "repository_data_reads": { "const": "verified_lock_and_exact_frozen_file_literals_plus_git_metadata_and_exact_ignore_files" },
        "repository_directory_reads": { "const": "metadata_and_exact_directory_entries_only" },
        "unfrozen_repository_file_data": { "const": "denied" },
        "private_writes": { "const": "exact_current_cell_or_scorer_temporary_subtree_only" },
        "node_modules": { "const": "canonical_local_non_symlink_directory" }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_before_private_cell_or_child", "claim_write", "failure_terminal", "hard_termination_without_terminal", "rerun_policy", "uniqueness_scope", "residual_limitation"],
      "properties": {
        "claim_before_private_cell_or_child": { "const": true },
        "claim_write": { "const": "o_excl_o_nofollow_fsync_file_and_parent" },
        "failure_terminal": { "const": "canonical_hashes_and_counts_only_o_excl_o_nofollow_fsync_file_and_parent" },
        "hard_termination_without_terminal": { "const": "aborted_no_pass" },
        "rerun_policy": { "const": "reject_if_claim_or_fixed_cell_receipt_or_terminal_exists_before_any_attempt_write" },
        "uniqueness_scope": { "const": "authoritative_worktree_only" },
        "residual_limitation": { "const": "copied_repositories_malicious_claim_deletion_or_same_user_forgery_require_procedural_external_audit" }
      }
    },
    "oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority_validator_version", "database_validator_version", "database_max_bytes", "normalized_item_video_page_asset_and_input_hash_binding", "positive_and_supported_report_preflight_counts_exact", "repeat_normalized_file_bytes_exact", "provider_network_llm_and_enrichment_attempts"],
      "properties": {
        "authority_validator_version": { "const": "1.0.0" },
        "database_validator_version": { "const": "1.0.0" },
        "database_max_bytes": { "const": 67108864 },
        "normalized_item_video_page_asset_and_input_hash_binding": { "const": true },
        "positive_and_supported_report_preflight_counts_exact": { "const": true },
        "repeat_normalized_file_bytes_exact": { "const": true },
        "provider_network_llm_and_enrichment_attempts": { "const": 0 }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sealed_default_dependencies_eligible", "development_test_only_eligible", "primary_private_content"],
      "properties": {
        "sealed_default_dependencies_eligible": { "const": true },
        "development_test_only_eligible": { "const": false },
        "primary_private_content": { "const": "never_publish" }
      }
    }
  }
}
