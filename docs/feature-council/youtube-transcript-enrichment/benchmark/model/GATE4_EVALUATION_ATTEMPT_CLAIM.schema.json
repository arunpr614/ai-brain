{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brain.arunp.in/schemas/youtube-gate4-evaluation-attempt-claim-v1.json",
  "title": "Repository-authoritative Gate 4 evaluation package or role attempt claim",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/packageClaim" },
    { "$ref": "#/$defs/roleClaim" }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "dateTime": { "type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$" },
    "role": { "enum": ["evaluator_a", "evaluator_b", "adjudicator"] },
    "hashMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluator_a", "evaluator_b", "adjudicator"],
      "properties": {
        "evaluator_a": { "$ref": "#/$defs/sha256" },
        "evaluator_b": { "$ref": "#/$defs/sha256" },
        "adjudicator": { "$ref": "#/$defs/sha256" }
      }
    },
    "common": {
      "type": "object",
      "required": ["schema_version", "execution_class", "publication_eligible", "content_commit", "seal_commit", "benchmark_lock_sha256", "external_provider_calls", "external_content_transfer", "claims_boundary"],
      "properties": {
        "schema_version": { "const": "1.0" },
        "execution_class": { "enum": ["SEALED", "DEV_TEST"] },
        "publication_eligible": { "type": "boolean" },
        "content_commit": { "$ref": "#/$defs/gitSha" },
        "seal_commit": { "$ref": "#/$defs/gitSha" },
        "benchmark_lock_sha256": { "$ref": "#/$defs/sha256" },
        "external_provider_calls": { "const": 0 },
        "external_content_transfer": { "const": false },
        "claims_boundary": { "const": "ai_evaluated_provisional_pending_human_stakeholder_review" }
      },
      "allOf": [
        { "if": { "type": "object", "properties": { "execution_class": { "const": "SEALED" } }, "required": ["execution_class"] }, "then": { "type": "object", "properties": { "publication_eligible": { "const": true } } } },
        { "if": { "type": "object", "properties": { "execution_class": { "const": "DEV_TEST" } }, "required": ["execution_class"] }, "then": { "type": "object", "properties": { "publication_eligible": { "const": false } } } }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "gate_3_result_sha256", "gate_4_attempt_claim_sha256", "gate_4_public_report_sha256", "normalized_input_sha256", "enrichment_output_sha256", "gate_4_run_id"],
      "properties": {
        "item_id": { "type": "string" },
        "gate_3_result_sha256": { "$ref": "#/$defs/sha256" },
        "gate_4_attempt_claim_sha256": { "$ref": "#/$defs/sha256" },
        "gate_4_public_report_sha256": { "$ref": "#/$defs/sha256" },
        "normalized_input_sha256": { "$ref": "#/$defs/sha256" },
        "enrichment_output_sha256": { "$ref": "#/$defs/sha256" },
        "gate_4_run_id": { "type": "string", "pattern": "^YT-[0-9]{2}-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{12}$" }
      }
    },
    "packageClaim": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["claim_type", "operator_version", "claimed_at", "timeout_ms_per_role", "retry_policy", "gate_3_result_sha256", "execution_contract_sha256", "runtime_ledger_sha256", "llama_cli_sha256", "model_sha256", "sandbox_profile_sha256", "role_system_prompt_sha256", "role_generation_schema_sha256", "strict_postparse_schema_sha256", "consent_attestation_sha256", "execution_readiness_sha256", "sources", "package_location_policy"],
          "properties": {
            "claim_type": { "const": "canonical_blinded_packet_package_attempt" },
            "operator_version": { "const": "1.0.0" },
            "claimed_at": { "$ref": "#/$defs/dateTime" },
            "timeout_ms_per_role": { "const": 1800000 },
            "retry_policy": { "const": "one_package_attempt_and_one_process_per_role_no_retry" },
            "gate_3_result_sha256": { "$ref": "#/$defs/sha256" },
            "execution_contract_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_ledger_sha256": { "$ref": "#/$defs/sha256" },
            "llama_cli_sha256": { "$ref": "#/$defs/sha256" },
            "model_sha256": { "$ref": "#/$defs/sha256" },
            "sandbox_profile_sha256": { "$ref": "#/$defs/sha256" },
            "role_system_prompt_sha256": { "$ref": "#/$defs/hashMap" },
            "role_generation_schema_sha256": { "$ref": "#/$defs/hashMap" },
            "strict_postparse_schema_sha256": { "$ref": "#/$defs/hashMap" },
            "consent_attestation_sha256": { "$ref": "#/$defs/sha256" },
            "execution_readiness_sha256": { "$ref": "#/$defs/sha256" },
            "sources": {
              "type": "array",
              "minItems": 5,
              "maxItems": 5,
              "prefixItems": [
                { "allOf": [{ "$ref": "#/$defs/source" }, { "type": "object", "properties": { "item_id": { "const": "YT-01" } } }] },
                { "allOf": [{ "$ref": "#/$defs/source" }, { "type": "object", "properties": { "item_id": { "const": "YT-02" } } }] },
                { "allOf": [{ "$ref": "#/$defs/source" }, { "type": "object", "properties": { "item_id": { "const": "YT-07" } } }] },
                { "allOf": [{ "$ref": "#/$defs/source" }, { "type": "object", "properties": { "item_id": { "const": "YT-08" } } }] },
                { "allOf": [{ "$ref": "#/$defs/source" }, { "type": "object", "properties": { "item_id": { "const": "YT-09" } } }] }
              ],
              "items": false
            },
            "package_location_policy": { "const": "private_evidence_root_outputs_seal_gate4_evaluation_package" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "roleClaim": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "required": ["claim_type", "runner_version", "role", "claimed_at", "timeout_ms", "retry_policy", "public_package_attempt_claim_sha256", "package_receipt_sha256", "bundle_sha256", "packet_id", "packet_sha256", "execution_contract_sha256", "runtime_ledger_sha256", "llama_cli_sha256", "model_sha256", "role_system_prompt_sha256", "role_generation_schema_sha256", "strict_postparse_schema_sha256", "sandbox_profile_sha256"],
          "properties": {
            "claim_type": { "const": "canonical_blinded_evaluator_role_attempt" },
            "runner_version": { "const": "1.0.0" },
            "role": { "$ref": "#/$defs/role" },
            "claimed_at": { "$ref": "#/$defs/dateTime" },
            "timeout_ms": { "const": 1800000 },
            "retry_policy": { "const": "one_write_once_role_invocation_no_retry" },
            "public_package_attempt_claim_sha256": { "$ref": "#/$defs/sha256" },
            "package_receipt_sha256": { "$ref": "#/$defs/sha256" },
            "bundle_sha256": { "$ref": "#/$defs/sha256" },
            "packet_id": { "type": "string", "pattern": "^G4-EVAL-[ABJ]-[0-9a-f]{12}$" },
            "packet_sha256": { "$ref": "#/$defs/sha256" },
            "execution_contract_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_ledger_sha256": { "$ref": "#/$defs/sha256" },
            "llama_cli_sha256": { "$ref": "#/$defs/sha256" },
            "model_sha256": { "$ref": "#/$defs/sha256" },
            "role_system_prompt_sha256": { "$ref": "#/$defs/sha256" },
            "role_generation_schema_sha256": { "$ref": "#/$defs/sha256" },
            "strict_postparse_schema_sha256": { "$ref": "#/$defs/sha256" },
            "sandbox_profile_sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  }
}
