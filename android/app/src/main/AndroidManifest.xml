<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              v0.5.0 T-11 / CAP-6 — Android share-sheet receiver.

              Per v0.0.1 S-003 spike + research §10 corrections: intent
              filters live on MainActivity directly (R-CAP proposed a
              separate ShareTargetActivity; that was wrong). The Capgo
              plugin (@capgo/capacitor-share-target@8.0.30) hooks into
              onNewIntent()/onCreate() and emits a `shareReceived` JS
              event with payload `{title, texts[], files[]}`.

              Three filters:
                1. text/plain (URLs, raw text from Chrome, Notes, etc.)
                2. application/pdf (single PDF from Drive, Gmail, etc.)
                3. ACTION_SEND_MULTIPLE application/pdf (multi-PDF share)

              F-041 2s cold-start dedup is server-side in T-12; nothing
              to do here in the manifest.

              NOTE: manual additions must sit BELOW the LAUNCHER filter.
              `cap sync` may rewrite content ABOVE this comment on a
              future plugin add; keep share-intent filters after that
              block (research §8 T-11 Capacitor footgun note).
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/pdf" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/pdf" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      v0.5.0 T-16 / F-037 — CAMERA permission for first-run QR scanning.
      The setup screen uses navigator.mediaDevices.getUserMedia() to stream
      the rear camera into a <video>, then decodes frames with jsqr. The
      permission prompt surfaces on first use (Android runtime permissions
      model — no app-install-time prompt). QR scanning is the ONLY use
      case; no Capacitor camera plugin is used (T-CF-12 removed the dep).
    -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
</manifest>
