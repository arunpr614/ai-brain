{
  "manifest_version": 3,
  "name": "Brain",
  "version": "0.5.3",
  "description": "Save pages to your local AI Brain library over a Cloudflare tunnel.",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Save to Brain"
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://brain.arunp.in/*"
  ]
}
