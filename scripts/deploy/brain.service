[Unit]
Description=AI Brain (Next.js standalone)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=brain
Group=brain-data
WorkingDirectory=/opt/brain
EnvironmentFile=/etc/brain/.env
EnvironmentFile=-/etc/brain/release.env
Environment=HOSTNAME=127.0.0.1
Environment=PORT=3000
Environment=BRAIN_BACKUP_STAGING_DIR=/run/brain-backup-staging
ExecStart=/usr/bin/node /opt/brain/current/server.js
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=brain

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
RuntimeDirectory=brain-backup-staging
RuntimeDirectoryMode=0700
RuntimeDirectoryPreserve=yes
ReadWritePaths=/opt/brain/data /run/brain-backup-staging
UMask=0007

[Install]
WantedBy=multi-user.target
