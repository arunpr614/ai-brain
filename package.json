{
  "name": "ai-brain",
  "version": "0.6.2",
  "description": "Personal knowledge base, hosted on Hetzner. Recall.it + Knowly features. Next.js + SQLite + Anthropic + Capacitor.",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arunpr614/ai-brain.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev -H 127.0.0.1",
    "build": "node scripts/build-next-safe.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/lib/llm/**/*.ts\" --test-coverage-include=\"src/lib/embed/**/*.ts\" --test-coverage-exclude=\"**/*.test.ts\" \"src/**/*.test.ts\"",
    "check:env": "bash scripts/check-env-gitignored.sh",
    "check:build-artifacts": "node scripts/check-build-artifacts.mjs",
    "build:apk": "bash scripts/build-apk.sh",
    "smoke": "node --import tsx scripts/smoke-v0.3.1.mjs && node --import tsx scripts/smoke-v0.4.0.mjs && node --import tsx scripts/smoke-v0.5.0.mjs && node --import tsx scripts/smoke-v0.5.1.mjs",
    "smoke:0.3.1": "node --import tsx scripts/smoke-v0.3.1.mjs",
    "smoke:0.4.0": "node --import tsx scripts/smoke-v0.4.0.mjs",
    "smoke:0.5.0": "node --import tsx scripts/smoke-v0.5.0.mjs",
    "smoke:0.5.1": "node --import tsx scripts/smoke-v0.5.1.mjs",
    "smoke:youtube": "node --import tsx scripts/smoke-youtube.mjs",
    "smoke:youtube:quality": "node --import tsx scripts/smoke-youtube-quality.mjs",
    "smoke:youtube:prod": "node --import tsx scripts/smoke-youtube-prod.mjs",
    "smoke:capture-quality": "node --import tsx scripts/spikes/capture-quality-eval.mjs",
    "smoke:telegram": "node scripts/smoke-telegram.mjs",
    "smoke:batch": "node --import tsx scripts/smoke-batch.ts",
    "backfill:embeddings": "node --import tsx scripts/backfill-embeddings.mjs",
    "backfill:embeddings:prod": "node scripts/backfill-embeddings-prod.mjs",
    "check:ai-providers": "node scripts/check-ai-providers.mjs",
    "bench:ask": "node --import tsx scripts/bench-ask.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capgo/capacitor-share-target": "^8.0.30",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/jsdom": "^28.0.1",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "next": "16.2.9",
    "node-cron": "^4.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sqlite-vec": "0.1.9",
    "tailwind-merge": "^2.5.5",
    "unpdf": "^1.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chrome-remote-interface": "^0.34.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "fake-indexeddb": "^6.2.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "overrides": {
    "sqlite-vec-darwin-arm64": "0.1.9",
    "sqlite-vec-darwin-x64": "0.1.9",
    "sqlite-vec-linux-arm64": "0.1.9",
    "sqlite-vec-linux-x64": "0.1.9",
    "sqlite-vec-windows-x64": "0.1.9",
    "next": {
      "postcss": "8.5.15"
    }
  }
}
