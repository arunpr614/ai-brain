{
  "name": "ai-brain",
  "version": "0.5.5",
  "description": "Local-first personal knowledge app combining Recall.it + Knowly features. Next.js + SQLite + Ollama + Capacitor. Pre-hosting until v1.0.0.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arunpr614/ai-brain.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev -H 127.0.0.1",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "start": "NODE_OPTIONS='--max-old-space-size=8192' next start -H 127.0.0.1",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "check:env": "bash scripts/check-env-gitignored.sh",
    "build:apk": "bash scripts/build-apk.sh",
    "smoke": "node --import tsx scripts/smoke-v0.3.1.mjs && node --import tsx scripts/smoke-v0.4.0.mjs && node --import tsx scripts/smoke-v0.5.0.mjs && node --import tsx scripts/smoke-v0.5.1.mjs",
    "smoke:0.3.1": "node --import tsx scripts/smoke-v0.3.1.mjs",
    "smoke:0.4.0": "node --import tsx scripts/smoke-v0.4.0.mjs",
    "smoke:0.5.0": "node --import tsx scripts/smoke-v0.5.0.mjs",
    "smoke:0.5.1": "node --import tsx scripts/smoke-v0.5.1.mjs",
    "smoke:youtube": "node --import tsx scripts/smoke-youtube.mjs",
    "backfill:embeddings": "node --import tsx scripts/backfill-embeddings.mjs",
    "bench:ask": "node --import tsx scripts/bench-ask.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capgo/capacitor-share-target": "^8.0.30",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/jsdom": "^28.0.1",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "idb": "^8.0.3",
    "jsdom": "^29.1.1",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "next": "16.2.5",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sqlite-vec": "0.1.9",
    "tailwind-merge": "^2.5.5",
    "unpdf": "^1.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "fake-indexeddb": "^6.2.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "overrides": {
    "sqlite-vec-darwin-arm64": "0.1.9",
    "sqlite-vec-darwin-x64": "0.1.9",
    "sqlite-vec-linux-arm64": "0.1.9",
    "sqlite-vec-linux-x64": "0.1.9",
    "sqlite-vec-windows-x64": "0.1.9"
  }
}
