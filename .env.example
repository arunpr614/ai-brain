# AI Brain — Example Environment Variables
#
# Copy this file to `.env` (git-ignored). The server auto-generates
# values on first run for anything left blank here; see comments per var.
#
# Never commit `.env` itself. `scripts/check-env-gitignored.sh` asserts
# this at test time.

# --- Core server ---

# SQLite database path. Defaults to `data/brain.sqlite` in the repo root.
# Override for tests or for running a second instance.
# BRAIN_DB_PATH=data/brain.sqlite

# --- Bearer auth (v0.5.0+; renamed in v0.6.1 T-11a) ---

# 32-byte hex bearer token for programmatic clients (Android APK + Chrome
# extension). Auto-generated on first server boot if absent; the generated
# value is written back to `.env` and logged as `lan.bearer.token-generated`
# in `data/errors.jsonl`.
#
# Rotate via Settings → Device Pairing or `scripts/rotate-token.sh`.
# All paired APKs and the Chrome extension will need re-setup after rotation.
# Must be at least 32 hex characters (128 bits); short/empty values are
# rejected by the proxy.
#
# v0.6.1 T-11a: renamed from BRAIN_LAN_TOKEN. The legacy name is still read
# as a fallback during the dual-read window; removal is scheduled for v0.6.2
# T-11b. Set BRAIN_API_TOKEN going forward.
# BRAIN_API_TOKEN=
# BRAIN_LAN_TOKEN=          # deprecated; remove in v0.6.2

# Requests-per-60-second limit per bearer token. Default 30.
# Rate limiter's job is to cap damage from runaway client bugs, not
# to defeat brute force (256-bit entropy already handles that).
# Renamed from BRAIN_LAN_RATE_LIMIT in v0.6.1 T-11a; legacy name still read.
# BRAIN_API_RATE_LIMIT=30

# --- Ollama (v0.3.0+) ---

# Ollama host + model names. Defaults match the research docs; override
# only if running Ollama on a non-default port or trying alternative models.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=qwen2.5:7b-instruct-q4_K_M
# OLLAMA_EMBED_MODEL=nomic-embed-text

# --- LLM provider wrapper (v0.6.0 B-7..B-13) ---
#
# AI Brain's enrichment + Ask paths route through a provider-agnostic
# wrapper. Each path picks its provider independently. Defaults are
# `ollama` so v0.5.6 behavior is unchanged; v0.6.0 cutover sets these
# to `anthropic` on Hetzner.
#
# Full doc: docs/llm-providers.md

# Enrichment path — daily batch + manual "Enrich now"
# LLM_ENRICH_PROVIDER=ollama        # ollama | anthropic | openrouter
# LLM_ENRICH_MODEL=                 # override default model per provider

# Ask path — realtime SSE streaming
# LLM_ASK_PROVIDER=ollama           # ollama | anthropic | openrouter
# LLM_ASK_MODEL=                    # override default model per provider

# Anthropic — required when *_PROVIDER=anthropic. Get a key at
# https://console.anthropic.com . Set a $5/mo hard cap in the dashboard.
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — required when *_PROVIDER=openrouter. Standby at v0.6.0
# (Anthropic-direct primary). Privacy block (data_collection: deny,
# allow_fallbacks: false) is enforced by src/lib/llm/openrouter.ts.
# OPENROUTER_API_KEY=sk-or-...

# --- Embedding provider wrapper (v0.6.0 B-9..B-11) ---
#
# Output dim is locked at 768 to match the chunks_vec schema.
# Providers that emit a different dim are rejected at the wrapper.

# EMBED_PROVIDER=ollama             # ollama | gemini
# EMBED_MODEL=                      # override default model per provider

# Gemini — required when EMBED_PROVIDER=gemini. gemini-embedding-001 with
# outputDimensionality=768 (Matryoshka truncation; matches chunks_vec).
# text-embedding-004 was the original lock; retired by Google before D-11.
# Free tier covers Brain's volume. Get a key at https://aistudio.google.com.
# Verify the "no training on paid tier" toggle if you upgrade.
# GEMINI_API_KEY=

# --- Off-site backup (v0.6.2 D-18) ---
#
# After every local snapshot (data/backups/*.sqlite), the scheduler
# encrypts the snapshot with `gpg --encrypt --recipient $BACKUP_GPG_RECIPIENT`
# and uploads the resulting `.gpg` blob to Backblaze B2 (`B2_BUCKET`).
# Local snapshot rotation is unaffected.
#
# Off-site upload is best-effort: errors log `[backup] off-site upload failed`
# and do not interrupt the schedule. If any of the four vars below is unset,
# off-site is silently disabled and the boot log shows `[backup] off-site
# disabled — <missing-var>`.
#
# Bucket is created with a 30-day lifecycle rule (D-4). The GPG private
# key + revocation cert MUST be escrowed in 1Password (`Brain — secrets`
# vault item) — without it, off-site backups are unrecoverable.
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET=brain-backups
# BACKUP_GPG_RECIPIENT=
